    {
        "name":  "capture_screenshot",
        "description":  "Ekran goruntusu al",
        "aliases":  [
                        "ekran resmi al",
                        "screenshot al",
                        "ekran goruntusu al"
                    ],
        "handler":  "powershell_inline",
        "chainable":  true,
        "script":  "$screenshotsDir = Join-Path $LibraryRepoBase \"data\\screenshots\"\nNew-Item -ItemType Directory -Path $screenshotsDir -Force | Out-Null\n$savePath = Join-Path $screenshotsDir (\"library-screenshot-\" + (Get-Date -Format \"yyyyMMdd-HHmmss\") + \".png\")\nAdd-Type -AssemblyName System.Windows.Forms\nAdd-Type -AssemblyName System.Drawing\n$bounds = [System.Windows.Forms.SystemInformation]::VirtualScreen\n$bitmap = New-Object System.Drawing.Bitmap $bounds.Width, $bounds.Height\n$graphics = [System.Drawing.Graphics]::FromImage($bitmap)\n$graphics.CopyFromScreen($bounds.X, $bounds.Y, 0, 0, $bitmap.Size)\n$bitmap.Save($savePath, [System.Drawing.Imaging.ImageFormat]::Png)\n$graphics.Dispose()\n$bitmap.Dispose()\nWrite-Output $savePath"
    },
    {
        "name":  "system_status_report",
        "description":  "Sistem durumu raporu al",
        "aliases":  [
                        "sistem raporu al",
                        "system status report"
                    ],
        "handler":  "powershell_inline",
        "chainable":  true,
        "script":  "$os = Get-CimInstance Win32_OperatingSystem\n$cpu = Get-CimInstance Win32_Processor | Select-Object -First 1\n[pscustomobject]@{\n    ComputerName = $env:COMPUTERNAME\n    OS = $os.Caption\n    RAM_GB = [math]::Round($os.TotalVisibleMemorySize / 1MB, 2)\n    CPU = $cpu.Name\n    FreePhysicalMemoryMB = [math]::Round($os.FreePhysicalMemory / 1KB, 2)\n} | ConvertTo-Json -Depth 4"
    },
    {
        "name":  "list_processes",
